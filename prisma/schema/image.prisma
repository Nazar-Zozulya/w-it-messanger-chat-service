model Image {
  id        Int      @id @default(autoincrement())
  base64    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shown     Boolean  @default(true)
  chat      Chat?    @relation("ChatAvatar")
  message   Message? @relation("messageImage", fields: [messageId], references: [id])
  messageId Int?
}
